# This app loads environment variables from **assets/.env** (see lib/main.dart).
#
# Setup:
#   1. Copy this file to:  assets/.env
#   2. Fill in your keys below.
#
# Gemini (food scan): https://aistudio.google.com/apikey
# Google Places (find nutritionists): Google Cloud Console → APIs & Services →
#   enable "Places API", then Credentials → Create API key.

GEMINI_API_KEY=
GOOGLE_PLACES_API_KEY=

# OpenCage (copy full block to assets/.env)
OPENCAGE_API_KEY=
# OPENCAGE_GEOCODE_BIAS=Lahore, Pakistan
