# Copy this file to `assets/.env` and add your keys.
# `assets/.env` is gitignored — never commit real secrets.

# Google Gemini (food scan)
GEMINI_API_KEY=

# Google Places API (nutritionist search — same key type as "Maps" keys from Cloud Console)
# Enable "Places API" (and billing if required) for your Google Cloud project.
GOOGLE_PLACES_API_KEY=

# OpenCage Geocoder (address autocomplete / forward geocoding)
# https://opencagedata.com/api
OPENCAGE_API_KEY=
# Optional: appended to the user's query (default in code: Lahore, Pakistan)
# OPENCAGE_GEOCODE_BIAS=Lahore, Pakistan
